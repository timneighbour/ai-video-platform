  "query": "\n-- Count all scenes that were ever dispatched to WaveSpeed (have a wavespeed taskId)\nSELECT \n  jobId,\n  COUNT(*) as totalScenes,\n  SUM(CASE WHEN taskId LIKE 'wavespeed:%' THEN 1 ELSE 0 END) as wavespeedDispatches,\n  SUM(CASE WHEN mvSceneStatus = 'completed' THEN 1 ELSE 0 END) as completed,\n  SUM(CASE WHEN mvSceneStatus = 'failed' THEN 1 ELSE 0 END) as failed,\n  SUM(CASE WHEN mvSceneStatus = 'generating' THEN 1 ELSE 0 END) as generating,\n  SUM(CASE WHEN mvSceneStatus = 'pending' THEN 1 ELSE 0 END) as pending\nFROM musicVideoScenes\nGROUP BY jobId\nORDER BY jobId DESC\nLIMIT 20;\n",
